# ============================================================
# Sima Arome — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/sima_arome?schema=public&sslmode=disable"

# Auth
JWT_SECRET="change-this-to-a-random-secret-in-production"
JWT_EXPIRES_IN="8h"

# Server
PORT=3000
NODE_ENV=development

# CORS (frontend URL)
CORS_ORIGIN=http://localhost:3001

# AI Services (optional — system works without them)
AI_PROVIDER=mock
YOLO_API_URL=http://localhost:8000
PPIC_API_URL=http://localhost:8001
SCHEDULER_URL=http://localhost:8001

# Demo Mode (set to true if AI services unavailable)
DEMO_MODE=false
