# ============================================================
# Sima Arome — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:sima_secret@localhost:5432/sima_arome?schema=public&sslmode=disable"

# Auth
JWT_SECRET="sima-arome-jwt-secret-change-in-production"
JWT_EXPIRES_IN="8h"

# Server
PORT=3000
NODE_ENV=development

# AI Scheduler (OR-Tools microservice URL)
SCHEDULER_URL=http://localhost:8001
