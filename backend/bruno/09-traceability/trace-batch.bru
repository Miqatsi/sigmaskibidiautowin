meta {
  name: Trace Batch (Backward)
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/traceability/{{batchLotNumber}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

tests {
  test("should return 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("should be FINISHED_GOOD type", function() {
    const body = res.getBody();
    expect(body.data.type).to.equal("FINISHED_GOOD");
  });
}
