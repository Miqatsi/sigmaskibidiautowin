meta {
  name: Get All Materials
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/materials
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

tests {
  test("should return 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("should return array", function() {
    const body = res.getBody();
    expect(body.data).to.be.an("array");
  });
}
