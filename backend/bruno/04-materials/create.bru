meta {
  name: Create Material
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/materials
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "name": "Bruno Test Material",
    "code": "MAT-{{$timestamp}}",
    "unit": "kg"
  }
}

script:post-response {
  const data = res.getBody();
  if (data.data) {
    bru.setVar("materialId", data.data.id);
  }
}

tests {
  test("should return 201", function() {
    expect(res.getStatus()).to.equal(201);
  });
}
